// 42 — Prisma schema
// The live game state lives in-memory inside the websocket game engine for speed.
// SQLite persists the operative profile and a log of resolved missions / high scores.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Operative {
  id        String   @id @default(cuid())
  codename  String   @unique
  tier      String   @default("BASIC") // BASIC | ELITE | ARCHON
  faction   String   @default("AXIOM") // AXIOM | VECTOR | NULLSEC
  authority Int      @default(10)
  victories Int      @default(0)
  defeats   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WarLog {
  id        String   @id @default(cuid())
  sol       Int
  operative String
  faction   String
  outcome   String   // VICTORY | DEFEAT | DRAW
  summary   String
  createdAt DateTime @default(now())
}
