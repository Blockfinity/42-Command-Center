# .graphifyignore — controls what graphify indexes for 42-Command-Center.
# Syntax is gitignore-compatible. Everything listed here is EXCLUDED from the
# knowledge graph so the graph maps only real 42-Command-Center project code.
#
# This file mirrors the 42 repo's .graphifyignore. Keep them in sync.

# --- Vendored / third-party source (NOT 42-Command-Center code) ---
vendor/
**/node_modules/
**/.venv/
**/venv/
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# --- Build / generated artifacts ---
**/dist/
**/build/
**/.next/
**/.turbo/
**/.cache/
**/out/
**/coverage/
**/.nyc_output/
**/*.tsbuildinfo

# --- Lock files (huge, no structural value) ---
**/*.lock
**/*.lockb
**/bun.lockb
**/package-lock.json
**/yarn.lock
**/poetry.lock
**/uv.lock

# --- Minified / generated JS (no semantic value) ---
**/*.min.js
**/*.min.css
**/*.map

# --- Autogenerated protobuf ---
**/*_pb2.py
**/*_pb2_grpc.py
**/*_pb2.pyi
**/*.pb.go

# --- Binary / media ---
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.webp
**/*.ico
**/*.svg
**/*.pdf
**/*.mp4
**/*.webm
**/*.woff
**/*.woff2
**/*.ttf
**/*.eot

# --- OS / editor cruft ---
.DS_Store
**/.DS_Store
Thumbs.db
**/*.swp
**/*.swo
**/*~
.idea/
.vscode/

# --- The graphify output itself (don't graph the graph) ---
graphify-out/

# --- Git ---
.git/

# --- Large data files ---
**/*.db
**/*.sqlite
**/*.sqlite3
**/*.parquet
**/*.arrow
